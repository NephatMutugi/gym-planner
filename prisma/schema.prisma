// Gym Planner — Phase 0 schema
// SQLite for local dev. JSON-string fields used where arrays would be needed
// (SQLite doesn't support native arrays). Swap to Postgres later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- NextAuth required tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domain models ---

model Household {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  users     User[]
  equipment Equipment[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile (filled during onboarding)
  age            Int?
  gender         String? // "male" | "female" | "other" | "prefer_not_to_say"
  heightCm       Float?
  bodyweightKg   Float?
  experience     String? // "beginner" | "intermediate" | "advanced"
  goals          String? // JSON array: ["general_fitness", "strength", ...]
  daysPerWeek    Int?
  sessionMinutes Int?
  injuries       String? // JSON array of free-text tags
  onboarded      Boolean @default(false)

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  accounts        Account[]
  sessions        Session[]
  privateEquipment Equipment[] @relation("UserEquipment")
}

model Equipment {
  id        String   @id @default(cuid())
  type      String // "dumbbell" | "kettlebell" | "barbell" | "plate" | "bench" | "pullup_bar" | "band" | "machine" | "bodyweight" | "other"
  label     String? // user-supplied label, e.g. "Powerblock 50s"
  // For weighted items: JSON array of weights in kg. e.g. "[2, 5, 10]"
  // For non-weighted: null or "[]"
  weightsKg String?
  notes     String?
  createdAt DateTime @default(now())

  // Either household-shared OR private to a user
  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("UserEquipment", fields: [userId], references: [id], onDelete: Cascade)
}
