// Gym Planner — Phase 2 schema
// SQLite for local dev. JSON-string fields used where arrays would be needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- NextAuth required tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domain models ---

model Household {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  users     User[]
  equipment Equipment[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile (filled during onboarding)
  age            Int?
  gender         String?
  heightCm       Float?
  bodyweightKg   Float?
  experience     String?
  goals          String?
  daysPerWeek    Int?
  sessionMinutes Int?
  injuries        String?
  postpartumWeeks Int? // weeks since giving birth, null = N/A
  onboarded      Boolean @default(false)

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  accounts         Account[]
  sessions         Session[]
  privateEquipment Equipment[] @relation("UserEquipment")
  programs         Program[]
}

model Equipment {
  id        String   @id @default(cuid())
  type      String
  label     String?
  weightsKg String?
  notes     String?
  createdAt DateTime @default(now())

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("UserEquipment", fields: [userId], references: [id], onDelete: Cascade)
}

// --- Program models (Phase 2) ---

model Program {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  split        String // e.g. "full_body_3x", "upper_lower_4x", "ppl_6x"
  daysPerWeek  Int
  goalsSnapshot String // JSON array of goals at generation time
  experience   String
  generatedAt  DateTime     @default(now())
  isActive     Boolean      @default(true)
  notes        String?

  days ProgramDay[]

  @@index([userId, isActive])
}

model ProgramDay {
  id        String        @id @default(cuid())
  programId String
  program   Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  order     Int           // 1-based day index within the week
  label     String        // e.g. "Full body A", "Upper", "Push"
  isRestDay Boolean       @default(false)

  items ProgramItem[]

  @@index([programId, order])
}

model ProgramItem {
  id           String     @id @default(cuid())
  dayId        String
  day          ProgramDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  order        Int
  exerciseId   String     // Matches Exercise.id in src/data/exercises.ts
  sets         Int
  repsMin      Int
  repsMax      Int
  targetLoadKg Float?     // null for bodyweight or iso holds
  holdSeconds  Int?       // for iso holds (planks etc.) instead of reps
  restSeconds  Int
  notes        String?

  @@index([dayId, order])
}
