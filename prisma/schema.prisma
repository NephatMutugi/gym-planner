// Gym Planner schema
// Postgres (Neon) for both local dev and production.
// JSON-string fields used for arrays (legacy from SQLite); can migrate to
// native String[] columns in a future phase.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- NextAuth required tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domain models ---

model Household {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  users     User[]
  equipment Equipment[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile (filled during onboarding)
  age            Int?
  gender         String?
  heightCm       Float?
  bodyweightKg   Float?
  experience     String?
  goals          String?
  daysPerWeek    Int?
  sessionMinutes Int?
  injuries        String?
  postpartumWeeks Int? // weeks since giving birth, null = N/A
  onboarded      Boolean @default(false)

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  accounts         Account[]
  sessions         Session[]
  privateEquipment Equipment[] @relation("UserEquipment")
  programs         Program[]
  workoutSessions  WorkoutSession[]
}

model Equipment {
  id        String   @id @default(cuid())
  type      String
  label     String?
  weightsKg String?
  notes     String?
  createdAt DateTime @default(now())

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("UserEquipment", fields: [userId], references: [id], onDelete: Cascade)
}

// --- Program models (Phase 2) ---

model Program {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  split        String // e.g. "full_body_3x", "upper_lower_4x", "ppl_6x"
  daysPerWeek  Int
  goalsSnapshot String // JSON array of goals at generation time
  experience   String
  generatedAt  DateTime     @default(now())
  isActive     Boolean      @default(true)
  notes        String?

  days ProgramDay[]

  @@index([userId, isActive])
}

model ProgramDay {
  id        String        @id @default(cuid())
  programId String
  program   Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  order     Int           // 1-based day index within the week
  label     String        // e.g. "Full body A", "Upper", "Push"
  isRestDay Boolean       @default(false)

  items    ProgramItem[]
  sessions WorkoutSession[]

  @@index([programId, order])
}

model ProgramItem {
  id           String     @id @default(cuid())
  dayId        String
  day          ProgramDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  order        Int
  exerciseId   String     // Matches Exercise.id in src/data/exercises.ts
  sets         Int
  repsMin      Int
  repsMax      Int
  targetLoadKg Float?     // null for bodyweight or iso holds
  holdSeconds  Int?       // for iso holds (planks etc.) instead of reps
  restSeconds  Int
  notes        String?

  @@index([dayId, order])
}

// --- Phase 3: Workout logging ---

model WorkoutSession {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  programDayId String?
  programDay   ProgramDay?  @relation(fields: [programDayId], references: [id], onDelete: SetNull)
  startedAt    DateTime     @default(now())
  completedAt  DateTime?
  notes        String?

  sets  SetLog[]
  items SessionItem[]

  @@index([userId, startedAt])
  @@index([userId, completedAt])
}

// Per-session snapshot of the prescribed exercise list. Created at session start
// from the ProgramDay's items; afterwards owned by the session so the user can
// add, skip, remove, or replace exercises without touching their program template.
//
// status:
//   PENDING  – default; counts toward progression
//   SKIPPED  – user marked it intentionally not done; kept visible with an undo
//   REMOVED  – soft-deleted from this session; hidden by default but kept for audit
//
// exerciseId is nullable to allow free-form custom entries (foam rolling, etc.)
// captured by customName instead. Custom items never feed back into progression.
model SessionItem {
  id                  String            @id @default(cuid())
  sessionId           String
  session             WorkoutSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceProgramItemId String?           // Null when added during the session (no original prescription)
  exerciseId          String?           // Matches Exercise.id; null for custom entries
  customName          String?           // Used when exerciseId is null
  order               Int               // Display order within the session
  sets                Int
  repsMin             Int
  repsMax             Int
  targetLoadKg        Float?
  holdSeconds         Int?
  restSeconds         Int
  notes               String?
  status              SessionItemStatus @default(PENDING)
  addedDuringSession  Boolean           @default(false)
  createdAt           DateTime          @default(now())

  setLogs SetLog[]

  @@index([sessionId, order])
  @@index([sessionId, status])
}

enum SessionItemStatus {
  PENDING
  SKIPPED
  REMOVED
}

model SetLog {
  id            String         @id @default(cuid())
  sessionId     String
  session       WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionItemId String?        // Reference to the SessionItem this set belongs to
  sessionItem   SessionItem?   @relation(fields: [sessionItemId], references: [id], onDelete: SetNull)
  exerciseId    String         // Matches Exercise.id in src/data/exercises.ts
  programItemId String?        // Legacy: original prescription. SessionItem.sourceProgramItemId is the new source of truth.
  setNumber     Int            // 1, 2, 3, ...
  weightKg      Float?         // null for bodyweight or skipped
  reps          Int?           // null for iso holds or skipped
  holdSeconds   Int?           // for iso holds
  rpe           Float?         // 1-10, perceived exertion (optional)
  skipped       Boolean        @default(false)
  notes         String?
  loggedAt      DateTime       @default(now())

  @@index([sessionId, setNumber])
  @@index([sessionItemId, setNumber])
  @@index([exerciseId])
}
