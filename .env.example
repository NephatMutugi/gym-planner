# Postgres (Neon recommended) — pooled URL for runtime
DATABASE_URL=""
# Direct (unpooled) URL for migrations / prisma db push
DIRECT_URL=""

NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Optional — required for Claude coaching features (explain, swap, weekly check-in).
# Without this, those features are hidden. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# --- Email (password reset) ---
# Optional — required for the password-reset email. Without RESEND_API_KEY +
# RESEND_FROM_EMAIL the reset flow still works end-to-end, but the email body
# is logged to the server console instead of being sent.
# Get an API key at https://resend.com after verifying a sender domain.
RESEND_API_KEY=""
# Format: "Gym Planner <noreply@yourdomain.com>"
RESEND_FROM_EMAIL=""

# Public base URL used to build absolute reset links. Defaults to the request's
# inferred origin if unset; set explicitly in production for safety.
APP_URL=""
